// ─── HOME ───
function renderHome(){
  const done = Object.keys(progress).length;
  const pct = Math.round(done/MODS.length*100);
  document.getElementById('prog-fill').style.width = pct+'%';
  document.getElementById('prog-txt').textContent = done+' / '+MODS.length;
  document.getElementById('mod-grid').innerHTML = MODS.map((m,i)=>{
    const isDone = progress[m.id];
    const isLocked = i > 0 && !progress[i-1];
    const cls = isLocked ? 'locked' : isDone ? 'done' : 'active-mod';
    const badge = isLocked ? '<span class="mod-badge mb-lock">BLOCAT</span>' : isDone ? '<span class="mod-badge mb-done">COMPLETAT</span>' : '<span class="mod-badge mb-active">INCEPE</span>';
