<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AIRI — Trading Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07080b;--bg2:#0d0f14;--bg3:#13161d;--bg4:#181c26;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.11);
  --text:#dde2f0;--text2:#7d889e;--text3:#3e4558;
  --accent:#5b8fff;--accent2:#8b5fff;--accentg:linear-gradient(135deg,#5b8fff,#8b5fff);
  --green:#27c97a;--red:#ff4f4f;--amber:#ffaa33;--pink:#ff6eb0;
  --mono:'Space Mono',monospace;--sans:'DM Sans',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow-x:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:15px;line-height:1.6}

/* ─── LAYOUT ─── */
.app{display:grid;grid-template-columns:260px 1fr;grid-template-rows:100vh;height:100vh}
@media(max-width:768px){.app{grid-template-columns:1fr;grid-template-rows:auto 1fr}}

/* ─── SIDEBAR ─── */
.sidebar{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sb-top{padding:22px 20px 18px;border-bottom:1px solid var(--border)}
.sb-logo{display:flex;align-items:center;gap:10px;margin-bottom:4px}
.logo-orb{width:32px;height:32px;border-radius:50%;background:var(--accentg);display:flex;align-items:center;justify-content:center;position:relative;flex-shrink:0}
.logo-orb::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:1px solid rgba(91,143,255,0.3);animation:orbpulse 3s infinite}
@keyframes orbpulse{0%,100%{transform:scale(1);opacity:0.6}50%{transform:scale(1.15);opacity:0.2}}
.logo-dot{width:10px;height:10px;border-radius:50%;background:white}
.logo-name{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--text);letter-spacing:1px}
.logo-sub{font-size:11px;color:var(--text3);letter-spacing:1.5px;font-family:var(--mono);margin-left:42px}
.sb-nav{flex:1;overflow-y:auto;padding:12px 10px}
.nav-section{margin-bottom:20px}
.nav-label{font-family:var(--mono);font-size:9px;color:var(--text3);letter-spacing:2px;padding:0 10px;margin-bottom:6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;cursor:pointer;transition:all 0.15s;border:1px solid transparent;margin-bottom:2px}
.nav-item:hover{background:var(--bg3)}
.nav-item.active{background:rgba(91,143,255,0.08);border-color:rgba(91,143,255,0.18)}
.nav-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.nav-text{font-size:13px;color:var(--text2);flex:1}
.nav-item.active .nav-text{color:var(--text)}
.nav-badge{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:3px}
.badge-new{background:rgba(91,143,255,0.15);color:var(--accent)}
.badge-done{background:rgba(39,201,122,0.12);color:var(--green)}
.nav-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sb-keys{padding:14px 16px;border-top:1px solid var(--border)}
.key-row{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.key-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.key-label{font-size:11px;color:var(--text3);flex:1;font-family:var(--mono)}
.key-status{font-size:10px;font-family:var(--mono)}
.key-status.ok{color:var(--green)}
.key-status.no{color:var(--red)}

/* ─── MAIN ─── */
.main{overflow-y:auto;display:flex;flex-direction:column}

/* ─── AIRI PANEL ─── */
.airi-panel{flex:0 0 auto;background:var(--bg2);border-bottom:1px solid var(--border);padding:24px 28px}
.airi-header{display:flex;align-items:center;gap:20px;margin-bottom:20px}
.airi-orb{width:64px;height:64px;border-radius:50%;background:var(--accentg);position:relative;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.airi-orb .ring{position:absolute;border-radius:50%;border:1.5px solid rgba(91,143,255,0.3)}
.airi-orb .ring1{inset:-8px;animation:ring 2.5s infinite}
.airi-orb .ring2{inset:-16px;animation:ring 2.5s 0.6s infinite}
.airi-orb .ring3{inset:-24px;animation:ring 2.5s 1.2s infinite}
@keyframes ring{0%{opacity:0.6;transform:scale(0.95)}100%{opacity:0;transform:scale(1.1)}}
.airi-orb.speaking .ring1,.airi-orb.speaking .ring2,.airi-orb.speaking .ring3{animation-duration:0.8s}
.airi-face{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.9);display:flex;align-items:center;justify-content:center}
.airi-face::after{content:'';width:10px;height:10px;border-radius:50%;background:var(--accent2)}
.airi-info{}
.airi-name{font-family:var(--mono);font-size:22px;font-weight:700;color:var(--text);letter-spacing:2px}
.airi-desc{font-size:13px;color:var(--text2);margin-top:2px}
.airi-state{display:flex;align-items:center;gap:6px;margin-top:6px}
.state-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.state-txt{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:1px}

/* Chat messages */
.airi-chat{max-height:260px;overflow-y:auto;margin-bottom:16px;display:flex;flex-direction:column;gap:10px;padding-right:4px}
.airi-chat::-webkit-scrollbar{width:3px}
.airi-chat::-webkit-scrollbar-track{background:transparent}
.airi-chat::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.msg{display:flex;gap:10px;align-items:flex-start}
.msg.user{flex-direction:row-reverse}
.msg-avatar{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700}
.msg-avatar.airi-av{background:var(--accentg)}
.msg-avatar.user-av{background:var(--bg4);color:var(--text2);border:1px solid var(--border2)}
.msg-bubble{max-width:85%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.6}
.msg.airi .msg-bubble{background:var(--bg4);color:var(--text);border-radius:4px 14px 14px 14px;border:1px solid var(--border)}
.msg.user .msg-bubble{background:rgba(91,143,255,0.12);color:var(--text);border:1px solid rgba(91,143,255,0.2);border-radius:14px 4px 14px 14px}
.msg-time{font-size:10px;color:var(--text3);font-family:var(--mono);margin-top:3px}
.typing-dots{display:flex;gap:4px;padding:4px 0}
.typing-dots span{width:6px;height:6px;border-radius:50%;background:var(--accent);opacity:0.4;animation:td 1.2s infinite}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes td{0%,100%{opacity:0.2;transform:translateY(0)}50%{opacity:1;transform:translateY(-3px)}}

/* Input */
.airi-input-row{display:flex;gap:8px;align-items:center}
.airi-input{flex:1;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:var(--sans);font-size:13px;padding:10px 14px;border-radius:10px;outline:none;transition:border-color 0.15s}
.airi-input:focus{border-color:rgba(91,143,255,0.4)}
.airi-input::placeholder{color:var(--text3)}
.send-btn{width:38px;height:38px;border-radius:10px;border:none;background:var(--accentg);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity 0.15s}
.send-btn:hover{opacity:0.85}
.send-btn svg{width:16px;height:16px;fill:white}
.mic-btn{width:38px;height:38px;border-radius:10px;border:1px solid var(--border2);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--text2);font-size:16px;transition:all 0.15s}
.mic-btn:hover{border-color:var(--border2);background:var(--bg3)}
.mic-btn.listening{border-color:rgba(255,79,79,0.5);background:rgba(255,79,79,0.08);color:var(--red);animation:micpulse 1s infinite}
@keyframes micpulse{0%,100%{box-shadow:0 0 0 0 rgba(255,79,79,0.3)}50%{box-shadow:0 0 0 6px rgba(255,79,79,0)}}

/* Quick prompts */
.quick-prompts{display:flex;gap:6px;flex-wrap:wrap;margin-top:12px}
.qp{font-size:11px;padding:5px 12px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text3);cursor:pointer;transition:all 0.15s;font-family:var(--mono);letter-spacing:0.5px}
.qp:hover{border-color:rgba(91,143,255,0.4);color:var(--accent)}

/* ─── CONTENT AREA ─── */
.content{flex:1;padding:24px 28px}

/* Screen */
.screen{display:none}
.screen.active{display:block}

/* Page header */
.page-tag{font-family:var(--mono);font-size:9px;color:var(--accent);letter-spacing:2.5px;margin-bottom:8px}
.page-title{font-size:26px;font-weight:600;color:var(--text);margin-bottom:6px;line-height:1.2}
.page-sub{font-size:14px;color:var(--text2)}

/* Progress */
.prog-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin:20px 0;display:flex;align-items:center;gap:14px}
.prog-bg{flex:1;height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:var(--accentg);border-radius:3px;transition:width .5s}
.prog-txt{font-family:var(--mono);font-size:11px;color:var(--text3);white-space:nowrap}

/* Module grid */
.mod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:12px;margin-bottom:24px}
.mod-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:18px;cursor:pointer;transition:all .2s}
.mod-card:hover:not(.locked){border-color:var(--border2);transform:translateY(-2px)}
.mod-card.locked{opacity:.35;cursor:not-allowed;pointer-events:none}
.mod-card.done{border-color:rgba(39,201,122,0.22)}
.mod-card.active-mod{border-color:rgba(91,143,255,0.3)}
.mod-icon-wrap{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:12px;background:var(--bg4)}
.mod-title{font-size:14px;font-weight:500;margin-bottom:3px}
.mod-sub-txt{font-size:11px;color:var(--text3)}
.mod-badge{display:inline-block;font-family:var(--mono);font-size:9px;padding:3px 8px;border-radius:4px;margin-top:10px;letter-spacing:.8px}
.mb-done{background:rgba(39,201,122,0.1);color:var(--green);border:1px solid rgba(39,201,122,0.2)}
.mb-active{background:rgba(91,143,255,0.1);color:var(--accent);border:1px solid rgba(91,143,255,0.18)}
.mb-lock{background:var(--bg4);color:var(--text3);border:1px solid var(--border)}

/* Lesson */
.lesson-card{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:22px;margin-bottom:18px}
.lc-tag{font-family:var(--mono);font-size:9px;color:var(--accent);letter-spacing:2px;margin-bottom:10px}
.lc-body{font-size:14px;color:var(--text2);line-height:1.85}
.lc-body p{margin-bottom:10px}
.lc-body strong{color:var(--text);font-weight:500}
.pills{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.pill{font-family:var(--mono);font-size:9px;padding:3px 9px;border-radius:4px;background:rgba(91,143,255,0.07);color:var(--accent);border:1px solid rgba(91,143,255,0.14);letter-spacing:.5px}

/* Visual */
.visual-wrap{border-radius:12px;overflow:hidden;border:1px solid var(--border);margin-bottom:18px}
.visual-header{background:var(--bg2);padding:8px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;font-family:var(--mono);font-size:9px;color:var(--text3)}
.visual-dot{width:7px;height:7px;border-radius:50%;background:var(--accent)}
.visual-body{background:#0b0e14;padding:16px}

/* Quiz */
.quiz-wrap{background:var(--bg3);border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:18px}
.quiz-tag{font-family:var(--mono);font-size:9px;color:var(--amber);letter-spacing:2px;margin-bottom:10px}
.quiz-q{font-size:14px;font-weight:500;color:var(--text);margin-bottom:14px;line-height:1.5}
.quiz-opts{display:flex;flex-direction:column;gap:8px}
.qo{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:11px 15px;font-family:var(--sans);font-size:13px;color:var(--text2);cursor:pointer;text-align:left;transition:all .15s}
.qo:hover:not(:disabled){border-color:var(--border2);color:var(--text)}
.qo.correct{border-color:rgba(39,201,122,0.45);background:rgba(39,201,122,0.07);color:var(--green)}
.qo.wrong{border-color:rgba(255,79,79,0.45);background:rgba(255,79,79,0.07);color:var(--red)}
.qo:disabled{cursor:not-allowed}

/* Mentor box */
.mentor-wrap{border-left:2px solid var(--accent);padding:12px 16px;background:rgba(91,143,255,0.04);border-radius:0 10px 10px 0;margin-top:14px}
.mentor-tag{font-family:var(--mono);font-size:9px;color:var(--accent);letter-spacing:2px;margin-bottom:6px}
.mentor-txt{font-size:13px;color:var(--text2);line-height:1.7}

/* Nav buttons */
.lesson-nav{display:flex;gap:10px;flex-wrap:wrap}
.btn{padding:9px 18px;border-radius:8px;border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:var(--sans);font-size:13px;cursor:pointer;transition:all .15s}
.btn:hover{background:var(--bg3);color:var(--text)}
.btn.primary{background:rgba(91,143,255,0.1);border-color:rgba(91,143,255,0.28);color:var(--accent)}
.btn.success{background:rgba(39,201,122,0.1);border-color:rgba(39,201,122,0.28);color:var(--green)}

/* Checklist */
.chklist{display:flex;flex-direction:column;gap:8px}
.chk{display:flex;align-items:flex-start;gap:12px;padding:13px 15px;border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:all .15s;background:var(--bg2)}
.chk:hover{border-color:var(--border2)}
.chk.on{border-color:rgba(39,201,122,0.28);background:rgba(39,201,122,0.04)}
.chk-box{width:22px;height:22px;border-radius:6px;border:1.5px solid var(--border2);flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;transition:all .15s}
.chk.on .chk-box{background:var(--green);border-color:var(--green)}
.chk-tick{display:none;color:#fff;font-size:11px;font-weight:700}
.chk.on .chk-tick{display:block}
.chk-title{font-size:13px;font-weight:500;color:var(--text)}
.chk.on .chk-title{color:var(--green)}
.chk-sub-txt{font-size:11px;color:var(--text3);margin-top:2px}
.chk-result{margin-top:14px;padding:13px;border-radius:10px;text-align:center;font-size:14px;font-weight:500;background:var(--bg3);color:var(--text3);transition:all .3s}
.chk-result.good{background:rgba(39,201,122,0.08);color:var(--green);border:1px solid rgba(39,201,122,0.18)}
.chk-result.partial{background:rgba(255,170,51,0.07);color:var(--amber)}

/* Stats */
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:20px}
.stat-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center}
.stat-n{font-size:28px;font-weight:600;font-family:var(--mono)}
.stat-l{font-size:10px;color:var(--text3);margin-top:3px;letter-spacing:.5px}

/* Setup table */
.setup-table{width:100%;border-collapse:collapse;font-size:13px}
.setup-table th{text-align:left;padding:8px 10px;font-family:var(--mono);font-size:9px;color:var(--text3);border-bottom:1px solid var(--border);letter-spacing:1px}
.setup-table td{padding:9px 10px;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:top}
.setup-table tr:last-child td{border-bottom:none}
.lv-badge{font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:3px;letter-spacing:.8px}
.lv-max{background:rgba(255,79,79,0.1);color:var(--red);border:1px solid rgba(255,79,79,0.2)}
.lv-high{background:rgba(255,170,51,0.1);color:var(--amber);border:1px solid rgba(255,170,51,0.2)}
.lv-med{background:rgba(91,143,255,0.1);color:var(--accent);border:1px solid rgba(91,143,255,0.18)}

/* Keys modal */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:100;align-items:center;justify-content:center}
.modal-bg.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:28px;max-width:440px;width:90%}
.modal h2{font-family:var(--mono);font-size:13px;color:var(--accent);letter-spacing:2px;margin-bottom:6px}
.modal p{font-size:13px;color:var(--text3);line-height:1.7;margin-bottom:16px}
.modal-field{margin-bottom:12px}
.modal-label{font-size:11px;color:var(--text3);font-family:var(--mono);letter-spacing:1px;margin-bottom:5px;display:block}
.modal-input{width:100%;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:var(--mono);font-size:11px;padding:9px 12px;border-radius:7px;outline:none}
.modal-input:focus{border-color:var(--accent)}
.modal-save{width:100%;background:linear-gradient(135deg,rgba(91,143,255,.15),rgba(139,95,255,.15));border:1px solid rgba(91,143,255,.3);color:var(--accent);font-family:var(--sans);font-size:13px;padding:10px;border-radius:8px;cursor:pointer;margin-top:4px}
.modal-save:hover{background:linear-gradient(135deg,rgba(91,143,255,.22),rgba(139,95,255,.22))}

/* Mobile */
.mob-header{display:none;background:var(--bg2);border-bottom:1px solid var(--border);padding:12px 16px;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
@media(max-width:768px){
  .app{grid-template-columns:1fr;height:auto}
  .sidebar{display:none;position:fixed;inset:0;z-index:50;width:260px}
  .sidebar.open{display:flex}
  .mob-header{display:flex}
  .airi-panel{padding:16px}
  .content{padding:16px}
}

/* Scrollbar global */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* Sound wave animation for speaking */
.sound-wave{display:flex;align-items:center;gap:3px;height:20px}
.wave-bar{width:3px;border-radius:2px;background:var(--accent);animation:wave 1.2s ease-in-out infinite}
.wave-bar:nth-child(1){height:6px;animation-delay:0s}
.wave-bar:nth-child(2){height:14px;animation-delay:.1s}
.wave-bar:nth-child(3){height:10px;animation-delay:.2s}
.wave-bar:nth-child(4){height:18px;animation-delay:.3s}
.wave-bar:nth-child(5){height:8px;animation-delay:.4s}
@keyframes wave{0%,100%{transform:scaleY(0.4)}50%{transform:scaleY(1)}}
</style>
</head>
<body>

<!-- KEYS MODAL -->
<div class="modal-bg" id="keys-modal">
  <div class="modal">
    <h2>CONFIGURARE API KEYS</h2>
    <p>AIRI are nevoie de doua chei pentru a functiona complet. Le poti adauga si separat — AIRI functioneaza si cu o singura cheie.</p>
    <div class="modal-field">
      <label class="modal-label">ANTHROPIC API KEY (AI + Web Search)</label>
      <input class="modal-input" type="password" id="inp-anthropic" placeholder="sk-ant-api03-..."/>
      <div style="font-size:10px;color:var(--text3);margin-top:4px">→ <a href="https://console.anthropic.com" target="_blank" style="color:var(--accent)">console.anthropic.com</a></div>
    </div>
    <div class="modal-field">
      <label class="modal-label">ELEVENLABS API KEY (Voce feminina)</label>
      <input class="modal-input" type="password" id="inp-eleven" placeholder="sk_..."/>
      <div style="font-size:10px;color:var(--text3);margin-top:4px">→ <a href="https://elevenlabs.io" target="_blank" style="color:var(--accent)">elevenlabs.io</a> → Profile → API Key</div>
    </div>
    <button class="modal-save" onclick="saveKeys()">Salveaza si porneste AIRI</button>
  </div>
</div>

<div class="mob-header">
  <span style="font-family:var(--mono);font-size:13px;color:var(--accent);letter-spacing:2px">AIRI</span>
  <div style="display:flex;gap:8px">
    <button class="btn" style="font-size:11px;padding:5px 10px" onclick="openModal()">KEYS</button>
    <button class="btn" style="font-size:11px;padding:5px 10px" onclick="toggleSidebar()">MENIU</button>
  </div>
</div>

<div class="app">
  <!-- SIDEBAR -->
