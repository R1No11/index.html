// ─── QUIZ ───
async function answerQ(modId, optIdx){
  if(quizDone) return;
  quizDone = true;
  const m = MODS[modId];
  const correct = optIdx === m.quiz.correct;
  document.querySelectorAll('.qo').forEach((b,i)=>{
    b.disabled = true;
    if(i === m.quiz.correct) b.classList.add('correct');
    else if(i === optIdx && !correct) b.classList.add('wrong');
  });
  quizStats.t++; if(correct) quizStats.c++;
  localStorage.setItem('airi_qstats', JSON.stringify(quizStats));
  const baseExp = correct ? m.quiz.exp_r : m.quiz.exp_w;
  const area = document.getElementById('mentor-area');
  area.innerHTML = `<div class="mentor-wrap"><div class="mentor-tag">AIRI ${correct?'✓ CORECT':'✗ REVIZUIESTE'}</div><div class="mentor-txt"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  let mentorText = baseExp;
  if(ANTHROPIC_KEY){
    try{
      const res = await fetch('https://api.anthropic.com/v1/messages',{
        method:'POST',
        headers:{'Content-Type':'application/json','x-api-key':ANTHROPIC_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
        body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:200,
          system:'Esti AIRI, asistentul AI de trading bazat pe strategia SMC/ICT a lui Rares Gabriel. Raspunzi in romana, concis, max 3 propozitii. Esti direct, practic, incurajatoare. Adauga un insight practic extra specific strategiei.',
          messages:[{role:'user',content:`Studentul a raspuns ${correct?'CORECT':'GRESIT'} la: "${m.quiz.q}". Raspuns ales: "${m.quiz.opts[optIdx]}". Explicatia: "${baseExp}". Comentariu scurt mentor cu insight extra.`}]})
      });
      const d = await res.json();
      mentorText = d.content?.[0]?.text || baseExp;
    }catch(e){ mentorText = baseExp; }
  }
  area.querySelector('.mentor-txt').textContent = mentorText;
  if(correct){
    progress[modId] = true;
    localStorage.setItem('airi_progress', JSON.stringify(progress));
    renderHome(); renderSidebar(); updateStats();
    setTimeout(()=>{
      if(modId < MODS.length-1){
        area.innerHTML += `<button class="btn success" style="margin-top:12px;width:100%" onclick="openModule(${modId+1})">Urmatorul modul: ${MODS[modId+1].title} →</button>`;
      } else {
        area.innerHTML += `<div style="margin-top:12px;padding:14px;background:rgba(39,201,122,.08);border-radius:10px;border:1px solid rgba(39,201,122,.2);text-align:center;color:var(--green);font-weight:500">Toate modulele completate! Esti gata sa reincerci challenge-ul.</div>`;
      }
    }, 600);
  }
}

// ─── CHECKLIST ───
function renderChecklist(){
  document.getElementById('chk-list').innerHTML = CHECKLIST_DATA.map((c,i)=>`
    <div class="chk" onclick="toggleChk(this,${i})">
      <div class="chk-box"><span class="chk-tick">✓</span></div>
      <div><div class="chk-title">${c.title}</div><div class="chk-sub-txt">${c.sub}</div></div>
    </div>`).join('');
}
function toggleChk(el, idx){
  checks[idx] = !checks[idx];
  el.classList.toggle('on', checks[idx]);
  const total = checks.filter(Boolean).length;
  const res = document.getElementById('chk-res');
  if(total===5){ res.className='chk-result good'; res.textContent='Toate 5 confluente bifate — poti intra in trade!'; }
  else if(total>0){ res.className='chk-result partial'; res.textContent=`${total} / 5 — mai lipsesc ${5-total} confluente`; }
  else { res.className='chk-result'; res.textContent='0 / 5 confluente bifate'; }
}

// ─── STATS ───
function updateStats(){
  const done = Object.keys(progress).length;
  document.getElementById('st-done').textContent = done;
  document.getElementById('st-quiz').textContent = quizStats.t;
  document.getElementById('st-rate').textContent = quizStats.t > 0 ? Math.round(quizStats.c/quizStats.t*100)+'%' : '0%';
  const concepts = [];
  MODS.forEach(m=>{ if(progress[m.id]) concepts.push(...m.concepts); });
  const el = document.getElementById('learned-pills');
  if(el) el.innerHTML = concepts.length ? concepts.map(c=>`<span class="pill">${c}</span>`).join('') : '<span style="color:var(--text3);font-size:13px">Niciun modul completat inca.</span>';
}

// ─── AIRI CHAT ───
function setAiriState(state){
  const dot = document.getElementById('state-dot');
  const txt = document.getElementById('state-txt');
  const orb = document.getElementById('airi-orb');
  if(state==='thinking'){ dot.style.background='var(--amber)'; txt.textContent='AIRI GANDESTE...'; orb.classList.remove('speaking'); }
  else if(state==='speaking'){ dot.style.background='var(--accent)'; txt.textContent='AIRI VORBESTE'; orb.classList.add('speaking'); }
  else { dot.style.background='var(--green)'; txt.textContent='ONLINE · GATA SA TE AJUT'; orb.classList.remove('speaking'); }
}

function addMsg(text, isUser){
  const log = document.getElementById('chat-log');
  const now = new Date().toLocaleTimeString('ro-RO',{hour:'2-digit',minute:'2-digit'});
  const div = document.createElement('div');
  div.className = 'msg ' + (isUser?'user':'airi');
  div.innerHTML = `
    <div class="msg-avatar ${isUser?'user-av':'airi-av'}">${isUser?'TU':'AI'}</div>
    <div>
      <div class="msg-bubble">${text}</div>
      <div class="msg-time">${now}</div>
    </div>`;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
  return div;
}

function addTyping(){
  const log = document.getElementById('chat-log');
  const div = document.createElement('div');
  div.className = 'msg airi';
  div.id = 'typing-indicator';
  div.innerHTML = `<div class="msg-avatar airi-av">AI</div><div><div class="msg-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>`;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

async function sendMsg(){
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if(!text) return;
  if(!ANTHROPIC_KEY){ addMsg('Te rog adauga API key-ul Anthropic din sectiunea KEYS.', false); return; }
  input.value = '';
  addMsg(text, true);
  addTyping();
  setAiriState('thinking');
  try{
    const res = await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',
      headers:{'Content-Type':'application/json','x-api-key':ANTHROPIC_KEY,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body:JSON.stringify({
        model:'claude-sonnet-4-20250514', max_tokens:400,
        tools:[{type:'web_search_20250305',name:'web_search'}],
        system:`Esti AIRI, asistentul personal de trading al utilizatorului. Esti bazata pe strategia SMC/ICT a lui Rares Gabriel de la Trading Institutional RO. Raspunzi in romana, concis si practic (max 4-5 propozitii). Esti feminina, directa si incurajatoare.

Cunostintele tale includ: Market Structure (BOS, CHoCH), Order Blocks, Fair Value Gap, Lichiditate (BSL/SSL/Sweep), Tipuri de setup (OG/TG/MG/SLG+), Regulile absolute, Gestionarea emotiilor in trading.

Daca utilizatorul intreaba despre preturi live sau stiri de piata, foloseste web search. Daca intreaba despre strategie, raspunde din cunostintele tale. Fii AIRI — nu Claude.`,
        messages:[{role:'user',content:text}]
      })
    });
    const d = await res.json();
    const reply = d.content?.filter(b=>b.type==='text').map(b=>b.text).join(' ') || 'Nu am putut genera un raspuns.';
    document.getElementById('typing-indicator')?.remove();
    addMsg(reply, false);
    speakWithElevenLabs(reply);
  }catch(e){
    document.getElementById('typing-indicator')?.remove();
    addMsg('Eroare la conectare. Verifica API key-ul.', false);
    setAiriState('idle');
  }
}

function quickAsk(text){
  document.getElementById('chat-input').value = text;
  sendMsg();
}

// ─── ELEVENLABS TTS ───
async function speakWithElevenLabs(text){
  if(!ELEVEN_KEY){ setAiriState('idle'); return; }
  setAiriState('speaking');
  try{
    const res = await fetch(`https://api.elevenlabs.io/v1/text-to-speech/${ELEVEN_VOICE_ID}`,{
      method:'POST',
      headers:{'Content-Type':'application/json','xi-api-key':ELEVEN_KEY},
      body:JSON.stringify({text:text.substring(0,500), model_id:'eleven_multilingual_v2', voice_settings:{stability:0.5,similarity_boost:0.8}})
    });
    if(!res.ok) throw new Error('ElevenLabs error');
    const blob = await res.blob();
    const url = URL.createObjectURL(blob);
    const audio = new Audio(url);
    audio.onended = ()=>{ setAiriState('idle'); URL.revokeObjectURL(url); };
    audio.play();
  }catch(e){ setAiriState('idle'); }
}

// ─── MIC / SPEECH RECOGNITION ───
function toggleMic(){
  if(!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)){
    addMsg('Browserul tau nu suporta recunoasterea vocala. Incearca Chrome.', false); return;
  }
  if(isListening){ recognition?.stop(); return; }
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();
  recognition.lang = 'ro-RO';
  recognition.interimResults = false;
  recognition.onstart = ()=>{ isListening=true; document.getElementById('mic-btn').classList.add('listening'); };
  recognition.onresult = (e)=>{ document.getElementById('chat-input').value = e.results[0][0].transcript; sendMsg(); };
  recognition.onend = ()=>{ isListening=false; document.getElementById('mic-btn').classList.remove('listening'); };
  recognition.start();
}

